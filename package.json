{
  "name": "mikerenoe",
  "version": "1.0.0",
  "description": "Personal website for Mike Renoe",
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "hugo-bin": "^0.149.2",
    "sass": "^1.99.0"
  },
  "scripts": {
    "css": "sass scss/index.scss static/scss/index.css --style=compressed --no-source-map",
    "build": "npm run css && hugo --gc --minify",
    "watch": "sass --watch scss/index.scss:static/scss/index.css",
    "preview": "npm run css && hugo server -D",
    "dev": "npm run preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrenoe/mikerenoe.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mrenoe/mikerenoe/issues"
  },
  "homepage": "https://github.com/mrenoe/mikerenoe#readme"
}
